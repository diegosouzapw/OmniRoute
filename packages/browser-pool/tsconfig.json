{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "lib": ["esnext"],
    "types": ["node"],
    "allowJs": false
  },
  "include": ["src/**/*.ts"]
}
