    {"type":"stat","title":"Throughput (rps)","targets":[{"expr":"sum(rate(latency_seconds_count[5m]))"}],"unit":"rps"},
    {"type":"table","title":"Top-10 Slowest Endpoints","targets":[{"expr":"topk(10, avg by(endpoint)(latency_seconds{quantile=\"0.99\"}[1h]))"}]}
