{
  "name": "sveltekit-dashboard",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check:tsgo": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo-experimental-api",
    "typecheck:fast": "svelte-kit sync && tsgo --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@typescript/native-preview": "^7.0.0-dev.20260702.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.27",
    "shadcn-svelte": "^1.3.0"
  }
}
