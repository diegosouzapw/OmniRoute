@@ -0,0 +1,25 @@
+# pheno-mcp-router — Environment variable reference
+#
+# Copy this file to .env and adjust values as needed.
+# All variables are OPTIONAL — the defaults shown below are used when
+# the variable is not set.
+#
+# Security-sensitive defaults (sanitize_keys, response_keys) are NOT
+# overridable via env vars — see config.py for documentation.
+
+# ── HTTP client ──────────────────────────────────────────────────────
+# Default timeout (seconds) for all backend HTTP calls.
+# PHENO_TIMEOUT_SECONDS=60.0
+
+# Maximum request payload in bytes before dispatch (DoS protection).
+# PHENO_MAX_MESSAGE_BYTES=128000
+
+# Maximum response payload in bytes from backend (DoS protection).
+# PHENO_MAX_RESPONSE_BYTES=512000
+
+# ── LLM provider API keys ────────────────────────────────────────────
+# OpenAI-compatible API key (used by OpenAIAdapter).
+# OPENAI_API_KEY=sk-...
+
+# Anthropic API key (used by AnthropicAdapter).
+# ANTHROPIC_API_KEY=sk-ant-...
