# Example environment configuration for Kogito.
# Copy this file to `.env` and uncomment the variables you need.

# ------------------------------------------------------------------------------
# Bifrost Configuration
# ------------------------------------------------------------------------------
# BIFROST_HOST=localhost
# BIFROST_PORT=8080
# BIFROST_API_KEY=your-api-key

# ------------------------------------------------------------------------------
# CLIProxy Configuration
# ------------------------------------------------------------------------------
# CLIPROXY_URL=https://cli-proxy.example.com
# CLIPROXY_TOKEN=your-proxy-token

# ------------------------------------------------------------------------------
# Deployment
# ------------------------------------------------------------------------------
# FLY_API_TOKEN=your-fly-token
# RAILWAY_TOKEN=your-railway-token
# RENDER_API_KEY=your-render-key
# VERCEL_TOKEN=your-vercel-token

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/kogito
# DATABASE_POOL_SIZE=10

# ------------------------------------------------------------------------------
# Cache
# ------------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=3600

# ------------------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------------------
# LOG_LEVEL=info
# METRICS_ENABLED=true
# TRACING_ENABLED=true
# OTEL_ENDPOINT=http://localhost:4317
