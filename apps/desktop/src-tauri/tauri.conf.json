{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "argismonitor",
  "version": "0.1.0",
  "identifier": "online.phenotype.argismonitor",
  "build": {
    "frontendDist": "http://localhost:4321",
    "devUrl": "http://localhost:4321"
  },
  "app": {
    "windows": [
      {
        "title": "argismonitor",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:4321 http://localhost:20128"
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png"],
    "category": "DeveloperTool",
    "shortDescription": "argismonitor desktop",
    "longDescription": "Unified AI router with 160+ providers, RTK+Caveman compression, auto fallback, MCP/A2A."
  }
}
