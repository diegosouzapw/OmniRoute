# Tauri 2 signing + auto-update

# Apple Developer ID (macOS codesign + notarize)
APPLE_CERTIFICATE=                       # base64 of .p12 cert
APPLE_CERTIFICATE_PASSWORD=
APPLE_SIGNING_IDENTITY=                  # "Developer ID Application: <Team> (<id>)"
APPLE_ID=                                # Apple ID for notarization
APPLE_PASSWORD=                          # app-specific password
APPLE_TEAM_ID=

# Windows code signing (Azure Trusted Signing / SignTool)
WINDOWS_CERTIFICATE=                     # base64 of .pfx
WINDOWS_CERTIFICATE_PASSWORD=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_ENDPOINT=https://wus2.trustedsignrs.us.attest.azure.net

# Auto-update channel
TAURI_SIGNING_PRIVATE_KEY=               # PEM private key (only at build time)
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Tauri updater pubkey (must match the one in tauri.conf.json -> plugins.updater.pubkey)
# Generated via: tauri signer generate -w ~/.tauri/argismonitor.key
