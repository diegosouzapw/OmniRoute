{
  "compilerOptions": {
    "target": "ES2025",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "jsx": "react-jsx",
    "lib": ["dom", "esnext"],
    "paths": {
      "@/*": ["../src/*"],
      "@omniroute/open-sse": ["."],
      "@omniroute/open-sse/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.js"]
}
