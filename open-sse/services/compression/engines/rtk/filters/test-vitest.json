{
  "id": "test-vitest",
  "name": "Vitest",
  "description": "Keep failing suites, failed tests, stack headers, and final summary.",
  "commandTypes": ["test-vitest"],
  "category": "test",
  "priority": 92,
  "stripPatterns": ["^\\s*✓\\s+", "^\\s*stdout \\|", "^\\s*stderr \\|"],
  "keepPatterns": [
    "^\\s*FAIL\\s+",
    "^\\s*❯\\s+",
    "^\\s*×\\s+",
    "Test Files\\s+",
    "Tests\\s+",
    "Duration\\s+",
    "Error:",
    "AssertionError",
    "\\s+at\\s+"
  ],
  "priorityPatterns": ["FAIL", "Error:", "AssertionError", "Test Files"],
  "collapsePatterns": ["^\\s*at "],
  "maxLines": 140,
  "preserveHead": 24,
  "preserveTail": 50
}
