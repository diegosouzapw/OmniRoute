# OpenTelemetry env vars (PR-001 default)
# Leave OTEL_EXPORTER_OTLP_ENDPOINT unset to disable span export (default).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/json
# OTEL_EXPORTER_OTLP_HEADERS=x-api-key=secret,x-tenant=42
# OTEL_TRACES_SAMPLER_ARG=1
# OTEL_BSP_MAX_QUEUE_SIZE=2048
# OTEL_BSP_SCHEDULE_DELAY=5000
# OTEL_SERVICE_NAME=omniroute
# OTEL_RESOURCE_ATTRIBUTES=deployment.region=us-east-1,deployment.environment=production
# OTEL_SDK_DISABLED=false

# LiveWS LAN allow-list (PR #4877 — already merged)
# Comma-separated host list. Loopback is always allowed.
# LIVE_WS_ALLOWED_HOSTS=100.96.135.160,192.168.1.20

# Authz LAN recognition (PR #4876 — closed by design)
# Tailscale CGNAT (100.64.0.0/10) is private-LAN by default.
# TAILSCALE_CIDR=disabled   # opt out
# Comma-separated extra IPv4 CIDRs for LAN overlays (ZeroTier, Nebula, ...).
# PRIVATE_LAN_CIDR=10.241.0.0/16,100.64.0.0/10

# Structured logger
OMNIROUTE_LOG_LEVEL=info
# OMNIROUTE_LOG_FORMAT=pretty

# Misc
DEPLOYMENT_ENVIRONMENT=development