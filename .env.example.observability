# Observability & Tenant-Cost environment template (PR-007)
# ------------------------------------------------------------
# Copy to .env.local and adjust. ALL variables are optional. The
# observability stack is default-off: setting OTEL_ENABLED=true is
# the only switch required to turn it on.

# ---- master switch --------------------------------------------------------
OTEL_ENABLED=false

# ---- service identity -----------------------------------------------------
OTEL_SERVICE_NAME=omniroute
OTEL_SERVICE_VERSION=3.8.34
OTEL_DEPLOYMENT_ENV=local
OTEL_SERVICE_NAMESPACE=omniroute
OTEL_SERVICE_INSTANCE_ID=

# ---- OTLP / HTTP exporter -------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TIMEOUT_MS=10000
OTEL_EXPORTER_OTLP_COMPRESSION=gzip

# ---- trace sampling -------------------------------------------------------
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=1.0

# ---- Prometheus metrics endpoint -----------------------------------------
OTEL_METRICS_ENABLED=true
OTEL_METRICS_INTERVAL_MS=15000
OTEL_METRICS_DEFAULT_LABELS=

# ---- log shipping ---------------------------------------------------------
OTEL_LOG_LEVEL=info
OTEL_LOG_PRETTY=false
OTEL_LOG_REDACT_KEYS=authorization,cookie,x-api-key

# ---- resource detector ---------------------------------------------------
OTEL_RESOURCE_HOST_NAME=
OTEL_RESOURCE_PROCESS_PID=
OTEL_RESOURCE_PROCESS_RUNTIME=node
OTEL_RESOURCE_PROCESS_RUNTIME_VERSION=
OTEL_RESOURCE_HOST_ARCH=

# ---- automatic instrumentation toggles ------------------------------------
OTEL_AUTO_INSTRUMENT_FETCH=true
OTEL_AUTO_INSTRUMENT_DB=true
OTEL_AUTO_INSTRUMENT_CACHE=true
OTEL_AUTO_INSTRUMENT_PROVIDER=true

# ---- proxy / span propagation --------------------------------------------
OTEL_TRACE_PROPAGATION=true
OTEL_PROXY_SPAN_KIND=internal
OTEL_PROXY_INCLUDE_HEADERS=x-tenant-id,x-request-id

# ---- tenant-cost (PR-007) -------------------------------------------------
# Pre-seed the tenant_id allow-list to guarantee canonical IDs never
# collapse to the "other" sentinel. Comma-separated.
OTEL_TENANT_LABEL_ALLOW_LIST=
# Override the static USD-conversion table for non-USD currencies.
# JSON object: {"EUR":1.10,"GBP":1.30,"JPY":0.0070}
OTEL_EXCHANGE_RATES=
