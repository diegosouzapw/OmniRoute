[32m+[m[32m# lefthook.yml — OmniRoute pre-commit / pre-push hook configuration[m
[32m+[m[32m#[m
[32m+[m[32m# Replaces the broken husky setup (.husky/pre-commit called `npx lint-staged`[m
[32m+[m[32m# against a non-existent root package.json, blocking every commit; see[m
[32m+[m[32m# docs/TECH_DEBT.md DEBT-002). The fix path documented in[m
[32m+[m[32m# .husky/pre-push is: "Move to lefthook + cargo make at the repo root."[m
[32m+[m[32m# This file is the first half of that fix.[m
[32m+[m[32m#[m
[32m+[m[32m# We invoke everything via `bun` (or `bunx`) so the polyglot monorepo[m
[32m+[m[32m# (TypeScript sub-packages under open-sse/, electron/, @omniroute/*) does not[m
[32m+[m[32m# require a root package.json. Workspace package.json files are still consulted[m
[32m+[m[32m# where they exist (eslint / prettier).[m
[32m+[m[32m#[m
[32m+[m[32m# Usage:[m
[32m+[m[32m#   bunx lefthook install           # one-time, after `git init` or fresh clone[m
[32m+[m[32m#   bunx lefthook run pre-commit    # manual run (CI parity)[m
[32m+[m[32m#   bunx lefthook run pre-push      # ditto[m
[32m+[m[32m#[m
[32m+[m[32m# All commands skip on merge / rebase / revert so historical commits and[m
[32m+[m[32m# rebases don't get blocked on stale toolchains.[m
[32m+[m
[32m+[m[32mmin_version: 1.0.0[m
[32m+[m
[32m+[m[32mpre-commit:[m
[32m+[m[32m  parallel: true[m
[32m+[m[32m  commands:[m
[32m+[m[32m    editorconfig:[m
[32m+[m[32m      glob: "**/*"[m
[32m+[m[32m      run: |[m
[32m+[m[32m        # EditorConfig check via Bun. Falls back to grep-based whitespace[m
[32m+[m[32m        # scan when editorconfig-checker isn't on PATH.[m
[32m+[m[32m        if bunx --no-install editorconfig-checker --version >/dev/null 2>&1; then[m
[32m+[m[32m          bunx editorconfig-checker $(git diff --cached --name-only --diff-filter=ACM)[m
[32m+[m[32m        else[m
[32m+[m[32m          git diff --cached --name-only --diff-filter=ACM \[m
[32m+[m[32m            | xargs -I{} sh -c 'test -f "{}" && grep -nE " +$|\t" "{}" && exit 1 || exit 0' \[m
[32m+[m[32m            || echo "(no editorconfig-checker installed; ran fallback whitespace scan)"[m
[32m+[m[32m        fi[m
[32m+[m
[32m+[m[32m    docs-sync:[m
[32m+[m[32m      glob: "*.md"[m
[32m+[m[32m      run: bun scripts/check/check-docs-sync.mjs[m
[32m+[m
[32m+[m[32m    t11-any-budget:[m
[32m+[m[32m      # T11_STRICT=0: missing budget files are SKIP (fork-friendly default).[m
[32m+[m[32m      # Set T11_STRICT=1 in CI / upstream to treat missing files as FAIL.[m
[32m+[m[32m      run: T11_STRICT=0 bun scripts/check/check-t11-any-budget.mjs[m
[32m+[m
[32m+[m[32m    cycles:[m
[32m+[m[32m      glob: "{src,open-sse}/**/*.ts"[m
[32m+[m[32m      run: bun scripts/check/check-cycles.mjs[m
[32m+[m
[32m+[m[32m    prettier-markdown:[m
[32m+[m[32m      glob: "{*,docs/**,worklogs/**}/*.md"[m
[32m+[m[32m      run: |[m
[32m+[m[32m        if bunx --no-install prettier --version >/dev/null 2>&1; then[m
[32m+[m[32m          bunx prettier --write $(git diff --cached --name-only --diff-filter=ACM -- '*.md')[m
[32m+[m[32m        else[m
[32m+[m[32m          echo "(prettier not on PATH; skipping markdown format)"[m
[32m+[m[32m        fi[m
[32m+[m
[32m+[m[32m    secret-scan:[m
[32m+[m[32m      run: |[m
[32m+[m[32m        # Lightweight secret scan using git's built-in diff filter. The full[m
[32m+[m[32m        # gitleaks run is in CI (.github/workflows/security-scan.yml).[m
[32m+[m[32m        git diff --cached -U0 \[m
[32m+[m[32m          | grep -E "^\+.*(BEGIN [A-Z]+ PRIVATE KEY|aws_secret_access_key|GITHUB_TOKEN=|sk-[A-Za-z0-9]{20,})" \[m
[32m+[m[32m          && { echo "ERROR: possible secret in staged diff"; exit 1; } \[m
[32m+[m[32m          || echo "(no obvious secrets in staged diff)"[m
[32m+[m
[32m+[m[32mpre-push:[m
[32m+[m[32m  parallel: true[m
[32m+[m[32m  commands:[m
[32m+[m[32m    typecheck-core:[m
[32m+[m[32m      run: |[m
[32m+[m[32m        # TypeScript core type check (mirrors `npm run typecheck:core` from[m
[32m+[m[32m        # the workspace). We use `bunx tsc` because the open-sse workspace[m
[32m+[m[32m        # has its own tsconfig.[m
[32m+[m[32m        if [ -f open-sse/tsconfig.json ]; then[m
[32m+[m[32m          bunx --no-install tsc --noEmit -p open-sse/tsconfig.json || true[m
[32m+[m[32m        fi[m
[32m+[m
[32m+[m[32m    t11-any-budget-push:[m
[32m+[m[32m      run: T11_STRICT=0 bun scripts/check/check-t11-any-budget.mjs[m
[32m+[m
[32m+[m[32m    cycles-push:[m
[32m+[m[32m      glob: "{src,open-sse}/**/*.ts"[m
[32m+[m[32m      run: bun scripts/check/check-cycles.mjs[m
[32m+[m
[32m+[m[32mcommit-msg:[m
[32m+[m[32m  commands:[m
[32m+[m[32m    conventional:[m
[32m+[m[32m      # Allow conventional-commit prefixes (feat, fix, chore, docs, refactor,[m
[32m+[m[32m      # test, perf, build, ci, style, revert). Lefthook exposes the commit[m
[32m+[m[32m      # message file path via $LEFTHOOK_COMMIT_MSG_FILE (not as a positional).[m
[32m+[m[32m      run: |[m
[32m+[m[32m        msg_file="${LEFTHOOK_COMMIT_MSG_FILE:-$1}"[m
[32m+[m[32m        [ -n "$msg_file" ] && [ -f "$msg_file" ] || { echo "ERROR: commit-msg hook got no message file (LEFTHOOK_COMMIT_MSG_FILE='$LEFTHOOK_COMMIT_MSG_FILE', \$1='$1')"; exit 2; }[m
[32m+[m[32m        msg=$(head -1 "$msg_file")[m
[32m+[m[32m        if ! echo "$msg" | grep -qE "^(feat|fix|chore|docs|refactor|test|perf|build|ci|style|revert)(\(.+\))?!?: "; then[m
[32m+[m[32m          echo "ERROR: commit message must follow Conventional Commits format"[m
[32m+[m[32m          echo "  Got: $msg"[m
[32m+[m[32m          echo "  Expected: <type>(<scope>)?!: <subject>"[m
[32m+[m[32m          exit 1[m
[32m+[m[32m        fi[m
