{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "incremental": true,
  "lineWidth": 120,
  "useTabs": false,
  "indentWidth": 4,
  "newLineKind": "lf",
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.4.0.wasm",
    "https://plugins.dprint.dev/dockerfile-0.4.0.wasm",
    "https://plugins.dprint.dev/ruff-0.1.2.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm"
  ],
  "excludes": [
    "target/**",
    "node_modules/**",
    "**/target/**",
    "**/node_modules/**",
    "**/.svelte-kit/**",
    "**/build/**",
    "**/dist/**",
    "**/vendor/**",
    "**/__pycache__/**",
    "**/.venv/**",
    "**/venv/**",
    "**/.pytest_cache/**",
    "**/site/**",
    "**/*.min.js",
    "**/*.min.css",
    "Cargo.lock"
  ],
  "ruff": {
    "lineLength": 120,
    "indentWidth": 4
  },
  "markdown": {
    "lineWidth": 120
  },
  "toml": {
    "lineWidth": 120,
    "indentWidth": 4
  }
}
